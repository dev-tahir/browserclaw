{
  "manifest_version": 3,
  "name": "AI Browser Control Agent",
  "version": "1.0.0",
  "description": "AI-powered browser automation with Ollama and OpenRouter support. Multi-tab control, tool calling, terminal access, and streaming chat.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "nativeMessaging",
    "debugger",
    "notifications",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "dashboard/dashboard.html",
  "chrome_url_overrides": {},
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "skills/*.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}
